# Root Gitignore

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# Build outputs
dist/
dist-ssr/
frontend/dist/
